# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Agent ports (optional — these are the defaults)
THERMOSTAT_PORT=8000
BIRTHDAYS_PORT=8001

# Gateway — single-port server for all agents + MCP SSE (runs instead of individual agent.py files)
GATEWAY_PORT=8080
GATEWAY_BASE_URL=https://8080yo372002.ngrok.io

# Public base URLs — used in OpenAPI spec served at /openapi.json
# Pattern: https://{PORT}yo372002.ngrok.io
THERMOSTAT_BASE_URL=https://8000yo372002.ngrok.io
BIRTHDAYS_BASE_URL=https://8001yo372002.ngrok.io

# MCP SSE transport — for claude.ai custom connector
# Run: python server.py --transport sse --port $THERMOSTAT_MCP_PORT
THERMOSTAT_MCP_PORT=9000
BIRTHDAYS_MCP_PORT=9001
THERMOSTAT_MCP_URL=https://9000yo372002.ngrok.io/sse
BIRTHDAYS_MCP_URL=https://9001yo372002.ngrok.io/sse
