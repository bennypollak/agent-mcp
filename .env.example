# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Agent ports (optional — these are the defaults)
THERMOSTAT_PORT=8000
BIRTHDAYS_PORT=8001

# Public base URLs — used in OpenAPI spec served at /openapi.json
# Pattern: https://{PORT}yo372002.ngrok.io
THERMOSTAT_BASE_URL=https://8000yo372002.ngrok.io
BIRTHDAYS_BASE_URL=https://8001yo372002.ngrok.io
